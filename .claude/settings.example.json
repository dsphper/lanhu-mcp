{
  "$schema": "https://claude.ai/schema/settings.json",
  "_comment": "Claude Code 项目配置示例 - 复制为 settings.local.json 使用",

  "plugins": {
    "_comment": "插件配置 - 根据项目类型启用相关插件",
    "_description": {
      "python": "Python 开发支持（代码补全、类型检查、虚拟环境）",
      "mcp": "MCP 协议支持（服务器开发、工具调试）",
      "git": "Git 版本控制支持",
      "docker": "Docker 容器支持",
      "http": "HTTP 客户端支持（API 测试、调试）",
      "playwright": "Playwright 浏览器自动化支持"
    },
    "enabled": [
      "python",
      "mcp",
      "git",
      "docker",
      "http",
      "playwright"
    ],
    "disabled": []
  },

  "permissions": {
    "_comment": "权限配置 - allow 允许自动执行，deny 禁止执行",
    "allow": [
      "pip install",
      "pip install -r requirements.txt",
      "pip show",
      "pip list",
      "python lanhu_mcp_server.py",
      "python -m pytest",
      "python -m pytest tests/ -v --cov",
      "black lanhu_mcp_server.py",
      "isort lanhu_mcp_server.py",
      "flake8 lanhu_mcp_server.py",
      "playwright install chromium",
      "docker-compose up -d",
      "docker-compose down",
      "docker-compose logs -f",
      "git status",
      "git diff",
      "git add",
      "git commit",
      "git push",
      "git pull"
    ],
    "deny": [
      "git push --force",
      "git reset --hard origin",
      "rm -rf .git"
    ]
  },

  "env": {
    "_comment": "环境变量配置",
    "PYTHONIOENCODING": "utf-8",
    "PYTHONUNBUFFERED": "1"
  },

  "apiConfiguration": {
    "_comment": "API 配置（可选）",
    "baseURL": "https://api.anthropic.com"
  },

  "mcpServers": {
    "_comment": "MCP 服务器配置",
    "lanhu": {
      "url": "http://localhost:8000/mcp?role=Developer&name=YourName",
      "disabled": false
    }
  },

  "hooks": {
    "_comment": "钩子配置（可选）- 在特定事件时执行命令",
    "PreToolUse": [],
    "PostToolUse": [],
    "Notification": []
  }
}
